# ─────────────────────────────────────────────
# VoucherPro — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# PostgreSQL connection string.
# On Replit this is auto-provisioned; for local dev use a local Postgres instance.
DATABASE_URL=postgresql://user:password@localhost:5432/voucherpro

# ── Auth ──────────────────────────────────────
# Secret used to sign JWT tokens. Use a long random string (32+ chars).
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret

# Session secret used by Express (cookie signing etc.)
SESSION_SECRET=change_me_to_another_long_random_secret

# ── Server ────────────────────────────────────
# Port the API server listens on. Injected automatically by Replit.
PORT=8080

# Node environment: development | production | test
NODE_ENV=development

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Frontend (Vite) ────────────────────────────
# Set by the Replit artifact runner. For local dev, set to the port Vite uses.
# PORT=5173   (frontend uses the same PORT env var, set per-artifact by the runner)
# BASE_PATH=/  (URL base path for the frontend app, injected by Replit)
